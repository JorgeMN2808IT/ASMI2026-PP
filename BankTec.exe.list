[ 338]        :                                       ; ==================================================
[ 339]        :                                       ; 4.2.2 DEPOSITAR DINERO
[ 340]        :                                       ; Reglas:
[ 341]        :                                       ; - solo cuentas activas
[ 342]        :                                       ; - monto positivo
[ 343]        :                                       ; ==================================================
[ 344]    0839:                                       DEPOSITAR_DINERO PROC
[ 345]    0839: BA 0A 01                              LEA DX, msgDepositar
[ 346]    083C: B4 09                                 MOV AH, 09h
[ 347]    083E: CD 21                                 INT 21h
[ 348]        :                                       
[ 349]        :                                       ; pedir numero de cuenta
[ 350]    0840: BA B2 02                              LEA DX, msgPedirCuentaDep
[ 351]    0843: B4 09                                 MOV AH, 09h
[ 352]    0845: CD 21                                 INT 21h
[ 353]        :                                       
[ 354]    0847: E8 D5 01                              CALL LEER_NUMERO
[ 355]    084A: 72 4C                                 JC NUMERO_INVALIDO_DEP
[ 356]        :                                       
[ 357]    084C: A3 F2 05                              MOV tempNumero, AX
[ 358]        :                                       
[ 359]        :                                       ; buscar cuenta
[ 360]    084F: E8 FC 00                              CALL BUSCAR_CUENTA
[ 361]    0852: 72 2C                                 JC CUENTA_NO_EXISTE_DEP
[ 362]        :                                       
[ 363]        :                                       ; DI queda apuntando a la cuenta encontrada
[ 364]    0854: 80 7D 18 01                           CMP BYTE PTR [DI + OFF_ESTADO], 1
[ 365]    0858: 75 2E                                 JNE CUENTA_INACTIVA_DEP
[ 366]        :                                       
[ 367]        :                                       ; pedir monto
[ 368]    085A: BA DB 02                              LEA DX, msgPedirMontoDep
[ 369]    085D: B4 09                                 MOV AH, 09h
[ 370]    085F: CD 21                                 INT 21h
[ 371]        :                                       
[ 372]    0861: E8 BB 01                              CALL LEER_NUMERO
[ 373]    0864: 72 32                                 JC NUMERO_INVALIDO_DEP
[ 374]        :                                       
[ 375]    0866: 3D 00 00                              CMP AX, 0
[ 376]    0869: 74 25                                 JE MONTO_INVALIDO_DEP
[ 377]        :                                       
[ 378]    086B: A3 F6 05                              MOV tempMonto, AX
[ 379]        :                                       
[ 380]        :                                       ; saldo = saldo + monto
[ 381]    086E: 8B 45 16                              MOV AX, [DI + OFF_SALDO]
[ 382]    0871: 03 06 F6 05                           ADD AX, tempMonto
[ 383]    0875: 89 45 16                              MOV [DI + OFF_SALDO], AX
[ 384]        :                                       
[ 385]    0878: BA 64 03                              LEA DX, msgDepositoOK
[ 386]    087B: B4 09                                 MOV AH, 09h
[ 387]    087D: CD 21                                 INT 21h
[ 388]    087F: C3                                    RET
[ 389]        :                                       
[ 390]    0880:                                       CUENTA_NO_EXISTE_DEP:
[ 391]    0880: BA F9 02                              LEA DX, msgCuentaNoExiste
[ 392]    0883: B4 09                                 MOV AH, 09h
[ 393]    0885: CD 21                                 INT 21h
[ 394]    0887: C3                                    RET
[ 395]        :                                       
[ 396]    0888:                                       CUENTA_INACTIVA_DEP:
[ 397]    0888: BA 19 03                              LEA DX, msgCuentaInactiva
[ 398]    088B: B4 09                                 MOV AH, 09h
[ 399]    088D: CD 21                                 INT 21h
[ 400]    088F: C3                                    RET
[ 401]        :                                       
[ 402]    0890:                                       MONTO_INVALIDO_DEP:
[ 403]    0890: BA 3D 03                              LEA DX, msgMontoInvalido
[ 404]    0893: B4 09                                 MOV AH, 09h
[ 405]    0895: CD 21                                 INT 21h
[ 406]    0897: C3                                    RET
[ 407]        :                                       
[ 408]    0898:                                       NUMERO_INVALIDO_DEP:
[ 409]    0898: BA 8E 02                              LEA DX, msgNumeroInvalido
[ 410]    089B: B4 09                                 MOV AH, 09h
[ 411]    089D: CD 21                                 INT 21h
[ 412]    089F: C3                                    RET
[ 413]        :                                       DEPOSITAR_DINERO ENDP
[ 414]        :                                       
[ 415]        :                                       ; ==================================================
[ 416]        :                                       ; 4.2.3 RETIRAR DINERO
[ 417]        :                                       ; Reglas:
[ 418]        :                                       ; - solo cuentas activas
[ 419]        :                                       ; - no permitir sobregiro
[ 420]        :                                       ; - mostrar error si fondos insuficientes
[ 421]        :                                       ; ==================================================
[ 422]    08A0:                                       RETIRAR_DINERO PROC
[ 423]        :                                       
[ 424]    08A0: BA 21 01                              LEA DX, msgRetirar
[ 425]    08A3: B4 09                                 MOV AH, 09h
[ 426]    08A5: CD 21                                 INT 21h
[ 427]        :                                       
[ 428]        :                                       ; pedir numero de cuenta
[ 429]    08A7: BA 8A 03                              LEA DX, msgPedirCuentaRet
[ 430]    08AA: B4 09                                 MOV AH, 09h
[ 431]    08AC: CD 21                                 INT 21h
[ 432]        :                                       
[ 433]    08AE: E8 6E 01                              CALL LEER_NUMERO
[ 434]    08B1: 72 5A                                 JC NUMERO_INVALIDO_RET
[ 435]        :                                       
[ 436]    08B3: A3 F2 05                              MOV tempNumero, AX
[ 437]        :                                       
[ 438]        :                                       ; buscar cuenta
[ 439]    08B6: E8 95 00                              CALL BUSCAR_CUENTA
[ 440]    08B9: 72 32                                 JC CUENTA_NO_EXISTE_RET
[ 441]        :                                       
[ 442]        :                                       ; verificar estado
[ 443]    08BB: 80 7D 18 01                           CMP BYTE PTR [DI + OFF_ESTADO], 1
[ 444]    08BF: 75 34                                 JNE CUENTA_INACTIVA_RET
[ 445]        :                                       
[ 446]        :                                       ; pedir monto a retirar
[ 447]    08C1: BA F6 03                              LEA DX, msgPedirMontoRet
[ 448]    08C4: B4 09                                 MOV AH, 09h
[ 449]    08C6: CD 21                                 INT 21h
[ 450]        :                                       
[ 451]    08C8: E8 54 01                              CALL LEER_NUMERO
[ 452]    08CB: 72 40                                 JC NUMERO_INVALIDO_RET
[ 453]        :                                       
[ 454]    08CD: 3D 00 00                              CMP AX, 0
[ 455]    08D0: 74 2B                                 JE MONTO_INVALIDO_RET
[ 456]        :                                       
[ 457]    08D2: A3 F6 05                              MOV tempMonto, AX
[ 458]        :                                       
[ 459]        :                                       ; verificar fondos suficientes
[ 460]    08D5: 8B 45 16                              MOV AX, [DI + OFF_SALDO]
[ 461]    08D8: 3B 06 F6 05                           CMP AX, tempMonto
[ 462]    08DC: 72 27                                 JB FONDOS_INSUFICIENTES
[ 463]        :                                       
[ 464]        :                                       ; saldo = saldo - monto
[ 465]    08DE: 2B 06 F6 05                           SUB AX, tempMonto
[ 466]    08E2: 89 45 16                              MOV [DI + OFF_SALDO], AX
[ 467]        :                                       
[ 468]    08E5: BA D2 03                              LEA DX, msgRetiroOK
[ 469]    08E8: B4 09                                 MOV AH, 09h
[ 470]    08EA: CD 21                                 INT 21h
[ 471]    08EC: C3                                    RET
[ 472]        :                                       
[ 473]    08ED:                                       CUENTA_NO_EXISTE_RET:
[ 474]    08ED: BA F9 02                              LEA DX, msgCuentaNoExiste
[ 475]    08F0: B4 09                                 MOV AH, 09h
[ 476]    08F2: CD 21                                 INT 21h
[ 477]    08F4: C3                                    RET
[ 478]        :                                       
[ 479]    08F5:                                       CUENTA_INACTIVA_RET:
[ 480]    08F5: BA 19 03                              LEA DX, msgCuentaInactiva
[ 481]    08F8: B4 09                                 MOV AH, 09h
[ 482]    08FA: CD 21                                 INT 21h
[ 483]    08FC: C3                                    RET
[ 484]        :                                       
[ 485]    08FD:                                       MONTO_INVALIDO_RET:
[ 486]    08FD: BA 3D 03                              LEA DX, msgMontoInvalido
[ 487]    0900: B4 09                                 MOV AH, 09h
[ 488]    0902: CD 21                                 INT 21h
[ 489]    0904: C3                                    RET
[ 490]        :                                       
[ 491]    0905:                                       FONDOS_INSUFICIENTES:
[ 492]    0905: BA B1 03                              LEA DX, msgFondosInsuficientes
[ 493]    0908: B4 09                                 MOV AH, 09h
[ 494]    090A: CD 21                                 INT 21h
[ 495]    090C: C3                                    RET
[ 496]        :                                       
[ 497]    090D:                                       NUMERO_INVALIDO_RET:
[ 498]    090D: BA 8E 02                              LEA DX, msgNumeroInvalido
[ 499]    0910: B4 09                                 MOV AH, 09h
[ 500]    0912: CD 21                                 INT 21h
[ 501]    0914: C3                                    RET
[ 502]        :                                       
[ 503]        :                                       RETIRAR_DINERO ENDP
