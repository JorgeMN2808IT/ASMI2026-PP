[ 325]    0829: BA 8E 02                              LEA DX, msgNumeroInvalido
[ 326]    082C: B4 09                                 MOV AH, 09h
[ 327]    082E: CD 21                                 INT 21h
[ 328]    0830: C3                                    RET
[ 329]        :                                       
