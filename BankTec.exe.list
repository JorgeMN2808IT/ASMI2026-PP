[ 543]        :                                       
[ 544]    0815: BA 32 00                              LEA DX, opcion2
[ 545]    0818: B4 09                                 MOV AH, 09h
[ 546]    081A: CD 21                                 INT 21h
[ 547]        :                                       
[ 548]    081C: BA 48 00                              LEA DX, opcion3
[ 549]    081F: B4 09                                 MOV AH, 09h
[ 550]    0821: CD 21                                 INT 21h
[ 551]        :                                       
[ 552]    0823: BA 5C 00                              LEA DX, opcion4
[ 553]    0826: B4 09                                 MOV AH, 09h
[ 554]    0828: CD 21                                 INT 21h
[ 555]        :                                       
[ 556]    082A: BA 71 00                              LEA DX, opcion5
[ 557]    082D: B4 09                                 MOV AH, 09h
[ 558]    082F: CD 21                                 INT 21h
[ 559]        :                                       
[ 560]    0831: BA 8E 00                              LEA DX, opcion6
[ 561]    0834: B4 09                                 MOV AH, 09h
[ 562]    0836: CD 21                                 INT 21h
[ 563]        :                                       
[ 564]    0838: BA A5 00                              LEA DX, opcion7
[ 565]    083B: B4 09                                 MOV AH, 09h
[ 566]    083D: CD 21                                 INT 21h
[ 567]        :                                       
[ 568]    083F: BA B0 00                              LEA DX, pedirOpcion
[ 569]    0842: B4 09                                 MOV AH, 09h
