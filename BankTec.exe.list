[ 325]        :                                       ; pedir numero de cuenta
[ 326]    071D: BA B2 02                              LEA DX, msgPedirCuentaDep
[ 327]    0720: B4 09                                 MOV AH, 09h
[ 328]    0722: CD 21                                 INT 21h
[ 329]        :                                       
[ 330]    0724: E8 84 00                              CALL LEER_NUMERO
[ 331]    0727: 72 4C                                 JC NUMERO_INVALIDO_DEP
[ 332]        :                                       
[ 333]    0729: A3 CC 04                              MOV tempNumero, AX
[ 334]        :                                       
[ 335]        :                                       ; buscar cuenta
[ 336]    072C: E8 4E 00                              CALL BUSCAR_CUENTA
[ 337]    072F: 72 2C                                 JC CUENTA_NO_EXISTE_DEP
[ 338]        :                                       
[ 339]        :                                       ; DI queda apuntando a la cuenta encontrada
[ 340]    0731: 80 7D 18 01                           CMP BYTE PTR [DI + OFF_ESTADO], 1
[ 341]    0735: 75 2E                                 JNE CUENTA_INACTIVA_DEP
[ 342]        :                                       
[ 343]        :                                       ; pedir monto
[ 344]    0737: BA DB 02                              LEA DX, msgPedirMontoDep
[ 345]    073A: B4 09                                 MOV AH, 09h
[ 346]    073C: CD 21                                 INT 21h
[ 347]        :                                       
[ 348]    073E: E8 6A 00                              CALL LEER_NUMERO
[ 349]    0741: 72 32                                 JC NUMERO_INVALIDO_DEP
[ 350]        :                                       
[ 351]    0743: 3D 00 00                              CMP AX, 0
[ 352]    0746: 74 25                                 JE MONTO_INVALIDO_DEP
[ 353]        :                                       
[ 354]    0748: A3 D0 04                              MOV tempMonto, AX
[ 355]        :                                       
[ 356]        :                                       ; saldo = saldo + monto
[ 357]    074B: 8B 45 16                              MOV AX, [DI + OFF_SALDO]
[ 358]    074E: 03 06 D0 04                           ADD AX, tempMonto
[ 359]    0752: 89 45 16                              MOV [DI + OFF_SALDO], AX
[ 360]        :                                       
[ 361]    0755: BA 64 03                              LEA DX, msgDepositoOK
[ 362]    0758: B4 09                                 MOV AH, 09h
[ 363]    075A: CD 21                                 INT 21h
[ 364]    075C: C3                                    RET
[ 365]        :                                       
[ 366]    075D:                                       CUENTA_NO_EXISTE_DEP:
[ 367]    075D: BA F9 02                              LEA DX, msgCuentaNoExiste
[ 368]    0760: B4 09                                 MOV AH, 09h
[ 369]    0762: CD 21                                 INT 21h
[ 370]    0764: C3                                    RET
[ 371]        :                                       
[ 372]    0765:                                       CUENTA_INACTIVA_DEP:
[ 373]    0765: BA 19 03                              LEA DX, msgCuentaInactiva
[ 374]    0768: B4 09                                 MOV AH, 09h
[ 375]    076A: CD 21                                 INT 21h
[ 376]    076C: C3                                    RET
[ 377]        :                                       
[ 378]    076D:                                       MONTO_INVALIDO_DEP:
[ 379]    076D: BA 3D 03                              LEA DX, msgMontoInvalido
[ 380]    0770: B4 09                                 MOV AH, 09h
[ 381]    0772: CD 21                                 INT 21h
[ 382]    0774: C3                                    RET
[ 383]        :                                       
[ 384]    0775:                                       NUMERO_INVALIDO_DEP:
[ 385]    0775: BA 8E 02                              LEA DX, msgNumeroInvalido
[ 386]    0778: B4 09                                 MOV AH, 09h
[ 387]    077A: CD 21                                 INT 21h
[ 388]    077C: C3                                    RET
[ 389]        :                                       
[ 390]        :                                       DEPOSITAR_DINERO ENDP
[ 391]        :                                       
[ 392]        :                                       ; ==================================================
[ 393]        :                                       ; BUSCAR_CUENTA
[ 394]        :                                       ; Entrada:
[ 395]        :                                       ;   tempNumero = numero a buscar
[ 396]        :                                       ; Salida:
[ 397]        :                                       ;   CF = 0 si encuentra
[ 398]        :                                       ;   CF = 1 si no encuentra
[ 399]        :                                       ;   DI = direccion de la cuenta si existe
[ 400]        :                                       ; ==================================================
[ 401]    077D:                                       BUSCAR_CUENTA PROC
[ 402]    077D: BF B4 03                              LEA DI, cuentas
[ 403]    0780: 32 ED                                 XOR CH, CH
[ 404]    0782: 8A 0E AE 04                           MOV CL, totalCuentas
[ 405]        :                                       
[ 406]    0786: 80 F9 00                              CMP CL, 0
[ 407]    0789: 74 0D                                 JE NO_ENCONTRADA
[ 408]        :                                       
[ 409]    078B:                                       BUSCAR_LOOP:
[ 410]    078B: 8B 05                                 MOV AX, [DI + OFF_NUMERO]
[ 411]    078D: 3B 06 CC 04                           CMP AX, tempNumero
[ 412]    0791: 74 07                                 JE ENCONTRADA
[ 413]        :                                       
[ 414]    0793: 83 C7 19                              ADD DI, TAM_CUENTA
[ 415]    0796: E2 F3                                 LOOP BUSCAR_LOOP
[ 416]        :                                       
[ 417]    0798:                                       NO_ENCONTRADA:
[ 418]    0798: F9                                    STC
[ 419]    0799: C3                                    RET
[ 420]        :                                       
[ 421]    079A:                                       ENCONTRADA:
[ 422]    079A: F8                                    CLC
[ 423]    079B: C3                                    RET
[ 424]        :                                       
[ 425]        :                                       BUSCAR_CUENTA ENDP
[ 426]        :                                       
[ 427]        :                                       ; ==================================================
[ 428]        :                                       ; OBTENER_DIRECCION_NUEVA_CUENTA
[ 429]        :                                       ; Salida:
[ 430]        :                                       ;   DI = direccion del siguiente espacio libre
[ 431]        :                                       ; ==================================================
[ 432]    079C:                                       OBTENER_DIRECCION_NUEVA_CUENTA PROC
[ 433]    079C: BF B4 03                              LEA DI, cuentas
[ 434]        :                                       
[ 435]    079F: 33 C0                                 XOR AX, AX
[ 436]    07A1: A0 AE 04                              MOV AL, totalCuentas
[ 437]        :                                       
[ 438]    07A4: B3 19                                 MOV BL, TAM_CUENTA
[ 439]    07A6: F6 E3                                 MUL BL          ; AX = totalCuentas * TAM_CUENTA
[ 440]        :                                       
[ 441]    07A8: 03 F8                                 ADD DI, AX
[ 442]    07AA: C3                                    RET
[ 443]        :                                       OBTENER_DIRECCION_NUEVA_CUENTA ENDP
[ 444]        :                                       
[ 445]        :                                       ; ==================================================
[ 446]        :                                       ; LEER_NUMERO
[ 447]        :                                       ; Lee un numero positivo desde teclado
[ 448]        :                                       ; usando buffer DOS y convierte ASCII -> numero
[ 449]        :                                       ;
[ 450]        :                                       ; Salida:
[ 451]        :                                       ;   AX = valor
[ 452]        :                                       ;   CF = 0 correcto
[ 453]        :                                       ;   CF = 1 invalido
[ 454]        :                                       ; ==================================================
[ 455]    07AB:                                       LEER_NUMERO PROC
[ 456]    07AB: BA AF 04                              LEA DX, bufferNumero
[ 457]    07AE: B4 0A                                 MOV AH, 0Ah
[ 458]    07B0: CD 21                                 INT 21h
[ 459]        :                                       
[ 460]    07B2: 33 C0                                 XOR AX, AX
[ 461]    07B4: 33 DB                                 XOR BX, BX
[ 462]    07B6: 33 C9                                 XOR CX, CX
[ 463]    07B8: 33 D2                                 XOR DX, DX
[ 464]        :                                       
[ 465]    07BA: 8A 0E B0 04                           MOV CL, bufferNumero + 1
[ 466]    07BE: 80 F9 00                              CMP CL, 0
[ 467]    07C1: 74 30                                 JE NUMERO_INVALIDO
[ 468]        :                                       
[ 469]    07C3: BE B1 04                              LEA SI, bufferNumero + 2
[ 470]    07C6: 33 C0                                 XOR AX, AX
[ 471]        :                                       
[ 472]    07C8:                                       CONVERTIR_LOOP:
[ 473]    07C8: 8A 1C                                 MOV BL, [SI]
[ 474]        :                                       
[ 475]    07CA: 80 FB 30                              CMP BL, '0'
[ 476]    07CD: 72 24                                 JB NUMERO_INVALIDO
[ 477]        :                                       
[ 478]    07CF: 80 FB 39                              CMP BL, '9'
[ 479]    07D2: 77 1F                                 JA NUMERO_INVALIDO
[ 480]        :                                       
[ 481]    07D4: 80 EB 30                              SUB BL, '0'
[ 482]        :                                       
[ 483]    07D7: BA 00 00                              MOV DX, 0
[ 484]    07DA: B9 0A 00                              MOV CX, 10
[ 485]    07DD: F7 E1                                 MUL CX              ; AX = AX * 10
[ 486]    07DF: 83 FA 00                              CMP DX, 0
[ 487]    07E2: 75 0F                                 JNE NUMERO_INVALIDO
[ 488]        :                                       
[ 489]    07E4: 32 FF                                 XOR BH, BH
[ 490]    07E6: 03 C3                                 ADD AX, BX
[ 491]    07E8: 72 09                                 JC NUMERO_INVALIDO
[ 492]        :                                       
[ 493]    07EA: 46                                    INC SI
[ 494]    07EB: FE 0E B0 04                           DEC BYTE PTR [bufferNumero + 1]
[ 495]    07EF: 75 D7                                 JNZ CONVERTIR_LOOP
[ 496]        :                                       
[ 497]    07F1: F8                                    CLC
[ 498]    07F2: C3                                    RET
[ 499]        :                                       
[ 500]    07F3:                                       NUMERO_INVALIDO:
[ 501]    07F3: F9                                    STC
[ 502]    07F4: C3                                    RET
[ 503]        :                                       
[ 504]        :                                       LEER_NUMERO ENDP
[ 505]        :                                       
[ 506]        :                                       ; ==================================================
[ 507]        :                                       ; LEER_NOMBRE
[ 508]        :                                       ; Lee nombre con buffer DOS.
[ 509]        :                                       ; Debe tener al menos 1 caracter.
[ 510]        :                                       ; Salida:
[ 511]        :                                       ;   CF = 0 correcto
[ 512]        :                                       ;   CF = 1 invalido
[ 513]        :                                       ; ==================================================
[ 514]    07F5:                                       LEER_NOMBRE PROC
[ 515]    07F5: BA B6 04                              LEA DX, bufferNombre
[ 516]    07F8: B4 0A                                 MOV AH, 0Ah
[ 517]    07FA: CD 21                                 INT 21h
[ 518]        :                                       
[ 519]    07FC: A0 B7 04                              MOV AL, bufferNombre + 1
[ 520]    07FF: 3C 00                                 CMP AL, 0
[ 521]    0801: 74 02                                 JE NOMBRE_INVALIDO
[ 522]        :                                       
[ 523]    0803: F8                                    CLC
[ 524]    0804: C3                                    RET
[ 525]        :                                       
[ 526]    0805:                                       NOMBRE_INVALIDO:
[ 527]    0805: F9                                    STC
[ 528]    0806: C3                                    RET
[ 529]        :                                       
[ 530]        :                                       LEER_NOMBRE ENDP
[ 531]        :                                       
