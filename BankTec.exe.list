[ 286]    07F1: 80 F9 00                              CMP CL, 0
[ 287]    07F4: 74 0A                                 JE FIN_COPIAR_NOMBRE_NUEVO
[ 288]    07F6: 8A 04                                 MOV AL, [SI]
[ 289]    07F8: 88 05                                 MOV [DI], AL
[ 290]    07FA: 46                                    INC SI
[ 291]    07FB: 47                                    INC DI
[ 292]    07FC: FE C9                                 DEC CL
[ 293]    07FE: EB F1                                 JMP COPIAR_NOMBRE_NUEVO
[ 294]        :                                       
[ 295]    0800:                                       FIN_COPIAR_NOMBRE_NUEVO:
[ 296]        :                                       ; guardar saldo
[ 297]    0800: E8 0D 02                              CALL OBTENER_DIRECCION_NUEVA_CUENTA
[ 298]    0803: A1 F4 05                              MOV AX, tempSaldo
[ 299]    0806: 89 45 16                              MOV [DI + OFF_SALDO], AX
[ 300]        :                                       
[ 301]        :                                       ; estado = activa
[ 302]    0809: C6 45 18 01                           MOV BYTE PTR [DI + OFF_ESTADO], 1
[ 303]        :                                       
[ 304]        :                                       ; aumentar total
[ 305]    080D: FE 06 D4 05                           INC totalCuentas
[ 306]        :                                       
[ 307]    0811: BA FD 01                              LEA DX, msgCuentaCreada
[ 308]    0814: B4 09                                 MOV AH, 09h
[ 309]    0816: CD 21                                 INT 21h
[ 310]    0818: C3                                    RET
[ 311]        :                                       
[ 312]    0819:                                       BANCO_LLENO:
[ 313]    0819: BA 44 02                              LEA DX, msgBancoLleno
[ 314]    081C: B4 09                                 MOV AH, 09h
[ 315]    081E: CD 21                                 INT 21h
[ 316]    0820: C3                                    RET
[ 317]        :                                       
[ 318]    0821:                                       CUENTA_REPETIDA:
[ 319]    0821: BA 1E 02                              LEA DX, msgCuentaRepetida
[ 320]    0824: B4 09                                 MOV AH, 09h
[ 321]    0826: CD 21                                 INT 21h
[ 322]    0828: C3                                    RET
[ 323]        :                                       
