[ 505]        :                                       
[ 506]        :                                       ; ==================================================
[ 507]        :                                       ; 4.2.4 CONSULTAR SALDO
[ 508]        :                                       ; Busca una cuenta y muestra su saldo
[ 509]        :                                       ; ==================================================
[ 510]    0915:                                       CONSULTAR_SALDO PROC
[ 511]        :                                       
[ 512]    0915: BA 36 01                              LEA DX, msgConsultar
[ 513]    0918: B4 09                                 MOV AH, 09h
[ 514]    091A: CD 21                                 INT 21h
[ 515]        :                                       
[ 516]        :                                       ; pedir numero de cuenta
[ 517]    091C: BA 12 04                              LEA DX, msgPedirCuentaCon
[ 518]    091F: B4 09                                 MOV AH, 09h
[ 519]    0921: CD 21                                 INT 21h
[ 520]        :                                       
[ 521]    0923: E8 F9 00                              CALL LEER_NUMERO
[ 522]    0926: 72 1E                                 JC NUMERO_INVALIDO_CON
[ 523]        :                                       
[ 524]    0928: A3 F2 05                              MOV tempNumero, AX
[ 525]        :                                       
[ 526]        :                                       ; buscar cuenta
[ 527]    092B: E8 20 00                              CALL BUSCAR_CUENTA
[ 528]    092E: 72 0E                                 JC CUENTA_NO_EXISTE_CON
[ 529]        :                                       
[ 530]        :                                       ; mostrar mensaje
[ 531]    0930: BA 3B 04                              LEA DX, msgSaldoActual
[ 532]    0933: B4 09                                 MOV AH, 09h
[ 533]    0935: CD 21                                 INT 21h
[ 534]        :                                       
[ 535]        :                                       ; cargar saldo
[ 536]    0937: 8B 45 16                              MOV AX, [DI + OFF_SALDO]
[ 537]        :                                       
[ 538]        :                                       ; imprimir numero
[ 539]    093A: E8 96 01                              CALL IMPRIMIR_NUMERO
[ 540]        :                                       
[ 541]    093D: C3                                    RET
[ 542]        :                                       
[ 543]    093E:                                       CUENTA_NO_EXISTE_CON:
[ 544]    093E: BA F9 02                              LEA DX, msgCuentaNoExiste
[ 545]    0941: B4 09                                 MOV AH, 09h
[ 546]    0943: CD 21                                 INT 21h
[ 547]    0945: C3                                    RET
[ 548]        :                                       
[ 549]    0946:                                       NUMERO_INVALIDO_CON:
[ 550]    0946: BA 8E 02                              LEA DX, msgNumeroInvalido
[ 551]    0949: B4 09                                 MOV AH, 09h
[ 552]    094B: CD 21                                 INT 21h
[ 553]    094D: C3                                    RET
[ 554]        :                                       
[ 555]        :                                       CONSULTAR_SALDO ENDP
[ 556]        :                                       
[ 557]        :                                       
[ 558]    094E:                                       BUSCAR_CUENTA PROC
[ 559]    094E: BF DA 04                              LEA DI, cuentas
[ 560]    0951: 32 ED                                 XOR CH, CH
[ 561]    0953: 8A 0E D4 05                           MOV CL, totalCuentas
[ 562]        :                                       
[ 563]    0957: 80 F9 00                              CMP CL, 0
[ 564]    095A: 74 0D                                 JE NO_ENCONTRADA
[ 565]        :                                       
[ 566]    095C:                                       BUSCAR_LOOP:
[ 567]    095C: 8B 05                                 MOV AX, [DI + OFF_NUMERO]
[ 568]    095E: 3B 06 F2 05                           CMP AX, tempNumero
[ 569]    0962: 74 07                                 JE ENCONTRADA
[ 570]        :                                       
[ 571]    0964: 83 C7 19                              ADD DI, TAM_CUENTA
[ 572]    0967: E2 F3                                 LOOP BUSCAR_LOOP
[ 573]        :                                       
[ 574]    0969:                                       NO_ENCONTRADA:
[ 575]    0969: F9                                    STC
[ 576]    096A: C3                                    RET
[ 577]        :                                       
[ 578]    096B:                                       ENCONTRADA:
[ 579]    096B: F8                                    CLC
[ 580]    096C: C3                                    RET
[ 581]        :                                       
[ 582]        :                                       BUSCAR_CUENTA ENDP
[ 583]        :                                       ; ==================================================
[ 584]        :                                       
[ 585]        :                                       ; ==================================================
[ 586]        :                                       ; 4.2.5 REPORTE GENERAL
[ 587]        :                                       ; Recorre todas las cuentas y calcula estadísticas
[ 588]        :                                       ; ==================================================
[ 589]    096D:                                       REPORTE_GENERAL PROC
[ 590]        :                                       
[ 591]    096D: BA 4C 01                              LEA DX, msgReporte
[ 592]    0970: B4 09                                 MOV AH, 09h
[ 593]    0972: CD 21                                 INT 21h
[ 594]        :                                       
[ 595]        :                                       ; reiniciar contadores
[ 596]    0974: C7 06 F8 05 00 00                     MOV reporteActivas, 0
[ 597]    097A: C7 06 FA 05 00 00                     MOV reporteInactivas, 0
[ 598]    0980: C7 06 FC 05 00 00                     MOV reporteSaldoTotal, 0
[ 599]        :                                       
[ 600]    0986: B8 FF FF                              MOV AX, 0FFFFh
[ 601]    0989: A3 00 06                              MOV reporteMenor, AX
[ 602]        :                                       
[ 603]    098C: C7 06 FE 05 00 00                     MOV reporteMayor, 0
[ 604]        :                                       
[ 605]        :                                       ; preparar recorrido
[ 606]    0992: BF DA 04                              LEA DI, cuentas
[ 607]    0995: 32 ED                                 XOR CH, CH
[ 608]    0997: 8A 0E D4 05                           MOV CL, totalCuentas
[ 609]        :                                       
[ 610]    099B: 80 F9 00                              CMP CL, 0
[ 611]    099E: 74 2E                                 JE MOSTRAR_RESULTADOS
[ 612]        :                                       
[ 613]    09A0:                                       REPORTE_LOOP:
[ 614]        :                                       
[ 615]        :                                       ; verificar estado
[ 616]    09A0: 80 7D 18 01                           CMP BYTE PTR [DI + OFF_ESTADO], 1
[ 617]    09A4: 74 06                                 JE CUENTA_ACTIVA
[ 618]        :                                       
[ 619]    09A6:                                       CUENTA_INACTIVA:
[ 620]    09A6: FF 06 FA 05                           INC reporteInactivas
[ 621]    09AA: EB 04                                 JMP PROCESAR_SALDO
[ 622]        :                                       
[ 623]    09AC:                                       CUENTA_ACTIVA:
[ 624]    09AC: FF 06 F8 05                           INC reporteActivas
[ 625]        :                                       
[ 626]    09B0:                                       PROCESAR_SALDO:
[ 627]        :                                       
[ 628]    09B0: 8B 45 16                              MOV AX, [DI + OFF_SALDO]
[ 629]        :                                       
[ 630]        :                                       ; sumar saldo total
[ 631]    09B3: 01 06 FC 05                           ADD reporteSaldoTotal, AX
[ 632]        :                                       
[ 633]        :                                       ; verificar mayor saldo
[ 634]    09B7: 3B 06 FE 05                           CMP AX, reporteMayor
[ 635]    09BB: 76 03                                 JBE VERIFICAR_MENOR
[ 636]    09BD: A3 FE 05                              MOV reporteMayor, AX
[ 637]        :                                       
[ 638]    09C0:                                       VERIFICAR_MENOR:
[ 639]        :                                       
[ 640]    09C0: 3B 06 00 06                           CMP AX, reporteMenor
[ 641]    09C4: 73 03                                 JAE SIGUIENTE_CUENTA
[ 642]    09C6: A3 00 06                              MOV reporteMenor, AX
[ 643]        :                                       
[ 644]    09C9:                                       SIGUIENTE_CUENTA:
[ 645]        :                                       
[ 646]    09C9: 83 C7 19                              ADD DI, TAM_CUENTA
[ 647]    09CC: E2 D2                                 LOOP REPORTE_LOOP
[ 648]        :                                       
[ 649]    09CE:                                       MOSTRAR_RESULTADOS:
[ 650]        :                                       
[ 651]        :                                       ; mostrar activas
[ 652]    09CE: BA 4C 04                              LEA DX, msgTotalActivas
[ 653]    09D1: B4 09                                 MOV AH, 09h
[ 654]    09D3: CD 21                                 INT 21h
[ 655]        :                                       
[ 656]    09D5: A1 F8 05                              MOV AX, reporteActivas
[ 657]    09D8: E8 F8 00                              CALL IMPRIMIR_NUMERO
[ 658]        :                                       
[ 659]        :                                       ; mostrar inactivas
[ 660]    09DB: BA 60 04                              LEA DX, msgTotalInactivas
[ 661]    09DE: B4 09                                 MOV AH, 09h
[ 662]    09E0: CD 21                                 INT 21h
[ 663]        :                                       
[ 664]    09E2: A1 FA 05                              MOV AX, reporteInactivas
[ 665]    09E5: E8 EB 00                              CALL IMPRIMIR_NUMERO
[ 666]        :                                       
[ 667]        :                                       ; mostrar saldo total
[ 668]    09E8: BA 76 04                              LEA DX, msgSaldoBanco
[ 669]    09EB: B4 09                                 MOV AH, 09h
[ 670]    09ED: CD 21                                 INT 21h
[ 671]        :                                       
[ 672]    09EF: A1 FC 05                              MOV AX, reporteSaldoTotal
[ 673]    09F2: E8 DE 00                              CALL IMPRIMIR_NUMERO
[ 674]        :                                       
[ 675]        :                                       ; mostrar mayor saldo
[ 676]    09F5: BA 90 04                              LEA DX, msgMayorSaldo
[ 677]    09F8: B4 09                                 MOV AH, 09h
[ 678]    09FA: CD 21                                 INT 21h
[ 679]        :                                       
[ 680]    09FC: A1 FE 05                              MOV AX, reporteMayor
[ 681]    09FF: E8 D1 00                              CALL IMPRIMIR_NUMERO
[ 682]        :                                       
[ 683]        :                                       ; mostrar menor saldo
[ 684]    0A02: BA A0 04                              LEA DX, msgMenorSaldo
[ 685]    0A05: B4 09                                 MOV AH, 09h
[ 686]    0A07: CD 21                                 INT 21h
[ 687]        :                                       
[ 688]    0A09: A1 00 06                              MOV AX, reporteMenor
[ 689]    0A0C: E8 C4 00                              CALL IMPRIMIR_NUMERO
[ 690]        :                                       
[ 691]    0A0F: C3                                    RET
[ 692]        :                                       
[ 693]        :                                       REPORTE_GENERAL ENDP
[ 694]        :                                       ; ==================================================
[ 695]        :                                       
[ 696]        :                                       
[ 697]        :                                       ; ==================================================
[ 698]        :                                       ; OBTENER_DIRECCION_NUEVA_CUENTA
[ 699]        :                                       ; Salida:
[ 700]        :                                       ;   DI = direccion del siguiente espacio libre
[ 701]        :                                       ; ==================================================
[ 702]    0A10:                                       OBTENER_DIRECCION_NUEVA_CUENTA PROC
[ 703]    0A10: BF DA 04                              LEA DI, cuentas
[ 704]        :                                       
[ 705]    0A13: 33 C0                                 XOR AX, AX
[ 706]    0A15: A0 D4 05                              MOV AL, totalCuentas
[ 707]        :                                       
[ 708]    0A18: B3 19                                 MOV BL, TAM_CUENTA
[ 709]    0A1A: F6 E3                                 MUL BL          ; AX = totalCuentas * TAM_CUENTA
[ 710]        :                                       
[ 711]    0A1C: 03 F8                                 ADD DI, AX
[ 712]    0A1E: C3                                    RET
[ 713]        :                                       OBTENER_DIRECCION_NUEVA_CUENTA ENDP
[ 714]        :                                       
[ 715]        :                                       ; ==================================================
[ 716]        :                                       ; LEER_NUMERO
[ 717]        :                                       ; Lee un numero positivo desde teclado
[ 718]        :                                       ; usando buffer DOS y convierte ASCII -> numero
[ 719]        :                                       ;
[ 720]        :                                       ; Salida:
[ 721]        :                                       ;   AX = valor
[ 722]        :                                       ;   CF = 0 correcto
[ 723]        :                                       ;   CF = 1 invalido
[ 724]        :                                       ; ==================================================
[ 725]    0A1F:                                       LEER_NUMERO PROC
[ 726]    0A1F: BA D5 05                              LEA DX, bufferNumero
[ 727]    0A22: B4 0A                                 MOV AH, 0Ah
[ 728]    0A24: CD 21                                 INT 21h
[ 729]        :                                       
[ 730]    0A26: 33 C0                                 XOR AX, AX
[ 731]    0A28: 33 DB                                 XOR BX, BX
[ 732]    0A2A: 33 C9                                 XOR CX, CX
[ 733]    0A2C: 33 D2                                 XOR DX, DX
[ 734]        :                                       
[ 735]    0A2E: 8A 0E D6 05                           MOV CL, bufferNumero + 1
[ 736]    0A32: 80 F9 00                              CMP CL, 0
[ 737]    0A35: 74 30                                 JE NUMERO_INVALIDO
[ 738]        :                                       
[ 739]    0A37: BE D7 05                              LEA SI, bufferNumero + 2
[ 740]    0A3A: 33 C0                                 XOR AX, AX
[ 741]        :                                       
[ 742]    0A3C:                                       CONVERTIR_LOOP:
[ 743]    0A3C: 8A 1C                                 MOV BL, [SI]
[ 744]        :                                       
[ 745]    0A3E: 80 FB 30                              CMP BL, '0'
[ 746]    0A41: 72 24                                 JB NUMERO_INVALIDO
[ 747]        :                                       
[ 748]    0A43: 80 FB 39                              CMP BL, '9'
[ 749]    0A46: 77 1F                                 JA NUMERO_INVALIDO
[ 750]        :                                       
[ 751]    0A48: 80 EB 30                              SUB BL, '0'
[ 752]        :                                       
